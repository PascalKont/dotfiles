{{ if eq .chezmoi.os "linux" }}

[".config/oh-my-bash"]
  type = "git-repo"
  url = "https://github.com/ohmybash/oh-my-bash.git"
  refreshPeriod = "168h"

[".config/oh-my-bash-custom/plugins/fzf-bash-completion/fzf-bash-completion.sh"]
  type = "file"
  url = "https://raw.githubusercontent.com/lincheney/fzf-tab-completion/refs/heads/master/bash/fzf-bash-completion.sh"
  refreshPeriod = "168h"

{{-   if not (lookPath "node") }}
[".local/opt/node"]
  type = "archive"
  url = "https://nodejs.org/dist/v24.14.0/node-v24.14.0-linux-x64.tar.xz"
  stripComponents = 1
  exact = true
  refreshPeriod = "672h"
{{    end }}

{{    if eq .chezmoi.arch "amd64" }}
[".local/libexec/nvim.appimage"]
  type = "file"
  url = "https://github.com/neovim/neovim/releases/download/stable/nvim-linux-x86_64.appimage"
  refreshPeriod = "672h"
  executable = true
{{    end }}

{{    if eq .hosttype "full" "work" "external-work" "private" }}
{{      if eq .hyprland "true" }}
[".local/share/fonts/0xproto"]
  type = "archive"
  url = "https://github.com/ryanoasis/nerd-fonts/releases/download/v3.4.0/0xProto.zip"
  exact = true
  refreshPeriod = "672h"
  include = ["*.ttf"]

[".local/lib/autotiling"]
  type = "archive"
  url = "https://github.com/nwg-piotr/autotiling/archive/refs/tags/v1.9.3.zip"
  stripComponents = 2
  exact = true
  refreshPeriod = "672h"
  include = ["**/main.py"]
{{      end }}
  
{{    end }}
{{ end }}

{{ if eq .hosttype "work" "private" }}

{{ end }}

{{ if eq .chezmoi.os "windows" }}
["AppData/Local/Microsoft/Windows/Fonts/0xproto"]
  type = "archive"
  url = "https://github.com/ryanoasis/nerd-fonts/releases/download/v3.4.0/0xProto.zip"
  exact = true
  refreshPeriod = "672h"
  include = ["*.ttf"]
{{ end }}
